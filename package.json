{
	"name": "expense-manager",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=11.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest --run",
		"test:coverage": "vitest --run --coverage",
		"test:migrations": "scripts/test-migration-upgrade.sh",
		"test:attachment-recovery": "scripts/test-attachment-backup-recovery.sh",
		"test": "pnpm test:unit && pnpm test:e2e",
		"test:e2e": "node scripts/run-functional-e2e.mjs",
		"test:visual": "playwright test --config playwright.visual.config.ts",
		"test:performance": "playwright test --config playwright.performance.config.ts",
		"test:query-plans": "node scripts/test-usage-count-query-plans.mjs",
		"test:infrastructure": "pnpm build && playwright test --config playwright.infrastructure.config.ts",
		"test:smoke": "playwright test --config playwright.smoke.config.ts",
		"test:prometheus-rules": "scripts/ops/test-prometheus-rules.sh",
		"test:quality": "pnpm test:visual && pnpm test:performance && pnpm test:query-plans && pnpm test:infrastructure && pnpm test:smoke && pnpm test:prometheus-rules",
		"verify": "pnpm check && pnpm lint && pnpm test:migrations && pnpm test:attachment-recovery && pnpm test:coverage && pnpm build && PLAYWRIGHT_PREBUILT=true pnpm test:e2e && pnpm test:quality",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.0",
		"@types/nodemailer": "^8.0.1",
		"@types/qrcode": "^1.5.6",
		"@vitest/coverage-v8": "^4.1.10",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.3",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@lucide/svelte": "^1.24.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
		"@opentelemetry/resources": "^2.9.0",
		"@opentelemetry/sdk-node": "^0.220.0",
		"better-auth": "^1.6.23",
		"drizzle-orm": "^0.45.2",
		"nodemailer": "^9.0.3",
		"postgres": "^3.4.9",
		"qrcode": "^1.5.4",
		"zod": "^4.4.3"
	}
}
