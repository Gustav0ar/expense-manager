PUBLIC_APP_NAME="Expense Manager"
NODE_ENV="development"
ORIGIN="http://localhost:5173"
# Optional comma-separated extra public origins, for example a VPN/Tailscale URL.
TRUSTED_ORIGINS=""
APP_DOMAIN="localhost"
# Traefik production deploy. DOMAIN_NAME is a bare host; ORIGIN is the full URL.
DOMAIN_NAME="finance.example.com"
TRAEFIK_NETWORK="web"
TRAEFIK_HTTP_ENTRYPOINT="web"
TRAEFIK_ENTRYPOINT="websecure"
TRAEFIK_CERT_RESOLVER="le"
REGISTRY="ghcr.io"
IMAGE_OWNER_LOWERCASE="example"
IMAGE_TAG="latest"

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-high-entropy-secret"
# Rotation only: retain the old application secret until all queued invitations
# have expired or been explicitly resent. Compose defaults to /dev/null when no
# previous-secret file is configured.
BETTER_AUTH_SECRET_PREVIOUS=""
BETTER_AUTH_SECRET_PREVIOUS_SOURCE_FILE="/dev/null"
REQUIRE_EMAIL_VERIFICATION="false"
# Set to false to disable public self-service account registration.
ALLOW_REGISTRATION="true"

# Local example. Use a private value in production.
DATABASE_URL="postgres://expense_manager:expense_manager@localhost:5432/expense_manager"
DB_POOL_MAX="5"
DB_PREPARE_STATEMENTS="true"
UPLOAD_DIR="/app/uploads"
# Use true only when the app is reachable exclusively through a trusted reverse proxy.
TRUST_PROXY_HEADERS="false"
# Required when TRUST_PROXY_HEADERS=true. Accepts comma-separated IPv4/IPv6 CIDRs.
# Prefer the narrow subnet of a dedicated app/proxy network; do not trust every private network.
TRUSTED_PROXY_CIDR=""

POSTGRES_DB="expense_manager"
POSTGRES_USER="expense_manager"
POSTGRES_PASSWORD="replace-with-a-private-database-password"
# Remote encrypted backups with restic. Use a private repository and password in production.
BACKUP_ENABLED="true"
RESTIC_REPOSITORY="s3:s3.example.com/expense-manager-backups"
RESTIC_PASSWORD="replace-with-a-private-restic-password"
RESTIC_HOST="expense-manager"
RESTIC_INIT_REPOSITORY="true"
RESTIC_KEEP_DAILY="7"
RESTIC_KEEP_WEEKLY="4"
RESTIC_KEEP_MONTHLY="12"
RESTIC_CHECK_AFTER_BACKUP="false"
# Required only for S3-compatible restic repositories.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_DEFAULT_REGION=""

# Optional production resource limits used by docker-compose.yml.
APP_MEM_LIMIT="512m"
APP_CPUS="1.0"
POSTGRES_MEM_LIMIT="1g"
POSTGRES_CPUS="1.0"
CADDY_MEM_LIMIT="256m"
CADDY_CPUS="0.5"
BACKUP_MEM_LIMIT="256m"
BACKUP_CPUS="0.5"

# Optional email for password reset, verification, invitations and budget alerts.
# Supported values: auto, mailjet, sender, smtp, log.
EMAIL_PROVIDER="auto"

# Mailjet API production example:
# MAILJET_API_KEY="<mailjet-api-key>"
# MAILJET_SECRET_KEY="<mailjet-secret-key>"
# MAILJET_FROM="Expense Manager <no-reply@your-verified-domain.example>"
MAILJET_API_KEY=""
MAILJET_SECRET_KEY=""
MAILJET_FROM=""
# Optional Mailjet Event API feedback. Use a dedicated, randomly generated Basic
# Auth credential and configure the callback URL documented in docs/email.md.
MAILJET_WEBHOOK_USERNAME=""
MAILJET_WEBHOOK_PASSWORD=""

# Sender API legacy production example:
# SENDER_API_TOKEN="<sender-api-token>"
# SENDER_FROM="Expense Manager <no-reply@your-verified-domain.example>"
SENDER_API_TOKEN=""
SENDER_FROM=""

# Optional SMTP fallback.
# SMTP_HOST="in-v3.mailjet.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="<mailjet-api-key>"
# SMTP_PASSWORD="<mailjet-secret-key>"
# SMTP_FROM="Expense Manager <no-reply@your-verified-domain.example>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Optional OpenTelemetry tracing. Keep disabled unless an OTLP collector or Tempo
# endpoint is reachable from the app container.
OTEL_TRACING_ENABLED="false"
OTEL_SERVICE_NAME="expense-manager"
OTEL_DEPLOYMENT_ENVIRONMENT="production"
# Generic OTLP HTTP endpoint. The app appends /v1/traces automatically.
OTEL_EXPORTER_OTLP_ENDPOINT=""
# Optional explicit traces endpoint. Takes precedence over OTEL_EXPORTER_OTLP_ENDPOINT.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=""
# 0 disables new root traces; 1 captures every request. Start low in production.
OTEL_TRACES_SAMPLE_RATE="0.1"
