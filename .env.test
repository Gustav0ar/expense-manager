PUBLIC_APP_NAME="Expense Manager"
NODE_ENV="test"
ORIGIN="http://localhost:4173"
TRUSTED_ORIGINS=""
BETTER_AUTH_SECRET="test-secret-32-chars-long-xxxxxxxx"
REQUIRE_EMAIL_VERIFICATION="false"
ALLOW_REGISTRATION="true"
DATABASE_URL="postgres://expense_manager:expense_manager@localhost:5432/expense_manager"
DB_POOL_MAX="5"
DB_PREPARE_STATEMENTS="false"
UPLOAD_DIR="/tmp/expense-manager-uploads-verify"
TRUST_PROXY_HEADERS="false"
EMAIL_DELIVERY="log"
BETTER_AUTH_RATE_LIMIT_MAX="1000"
