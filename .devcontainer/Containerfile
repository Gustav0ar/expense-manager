FROM node:24-bookworm

RUN apt-get update \
	&& apt-get install -y --no-install-recommends \
		ca-certificates \
		curl \
		gnupg \
	&& install -d -m 0755 /usr/share/keyrings \
	&& curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
		| gpg --batch --dearmor -o /usr/share/keyrings/postgresql-pgdg.gpg \
	&& printf '%s\n' \
		'deb [signed-by=/usr/share/keyrings/postgresql-pgdg.gpg] https://apt.postgresql.org/pub/repos/apt bookworm-pgdg main' \
		> /etc/apt/sources.list.d/postgresql-pgdg.list \
	&& apt-get update \
	&& apt-get install -y --no-install-recommends \
		git \
		fonts-liberation \
		fonts-noto-color-emoji \
		libasound2 \
		libatk-bridge2.0-0 \
		libatk1.0-0 \
		libatspi2.0-0 \
		libcairo2 \
		libcups2 \
		libdbus-1-3 \
		libdrm2 \
		libfontconfig1 \
		libfreetype6 \
		libgbm1 \
		libglib2.0-0 \
		libnspr4 \
		libnss3 \
		libpango-1.0-0 \
		libx11-6 \
		libx11-xcb1 \
		libxcb1 \
		libxcomposite1 \
		libxdamage1 \
		libxext6 \
		libxfixes3 \
		libxkbcommon0 \
		libxrandr2 \
		openssh-client \
		openssl \
		postgresql-client-18 \
		prometheus \
	&& rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@11.9.0 --activate

ENV PNPM_HOME=/home/node/.local/share/pnpm
ENV PATH="${PNPM_HOME}:${PATH}"

RUN mkdir -p /home/node/.local/share/pnpm/store /home/node/.cache/ms-playwright \
	&& chown -R node:node /home/node/.local /home/node/.cache

USER node
RUN pnpm config set store-dir /home/node/.local/share/pnpm/store

WORKDIR /workspaces/expense-manager
